# --- IDEs and OS ---
.DS_Store
.vscode/
.idea/
*.swp

# --- C++ Build Artifacts ---
/build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.o
*.a
*.out

# --- TypeScript / Node.js ---
/node_modules/
/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# --- Dependencies ---

# Ignore compiled objects and libraries inside dependencies
deps/**/*.o
deps/**/*.a
deps/**/*.so
deps/**/*.dylib

# But make sure we ARE tracking the source
!deps/**/*.c
!deps/**/*.h

# --- Assets ---
# Often you want to keep assets, but if you have large 
# test assets (100MB+ videos/fonts), you might ignore them.
# /assets/*.log
